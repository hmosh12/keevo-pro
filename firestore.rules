rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net & Default Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (The Primitives)
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } // Relaxed to isSignedIn for dev environment and initial setup
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Auth helpers derived from database state
    function getUserData(uid) { return get(/databases/$(database)/documents/users/$(uid)).data; }
    function userRole() { return getUserData(request.auth.uid).role; }
    function userCompany() { return getUserData(request.auth.uid).companyId; }
    
    function isOwner(uid) { return isVerified() && request.auth.uid == uid; }
    
    function isAdmin() { 
      return isVerified() && (
        userRole() == 'admin' || 
        request.auth.token.email == "tmojsd12@gmail.com"
      );
    }
    
    function isAccountant() { return isVerified() && (userRole() == 'admin' || userRole() == 'accountant'); }
    function isCashier() { return isVerified() && (userRole() == 'admin' || userRole() == 'accountant' || userRole() == 'cashier'); }
    
    function belongsToCompany(companyId) {
      return isVerified() && userCompany() == companyId;
    }

    // ===============================================================
    // Validation Blueprints (Anti-Update-Gap)
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'companyId']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['admin', 'accountant', 'cashier'] &&
             data.companyId is string && data.companyId.size() <= 128;
    }

    function isValidCompany(data) {
      return data.keys().hasAll(['name', 'ownerId']) &&
             data.name is string && data.name.size() <= 200 &&
             data.ownerId == request.auth.uid;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'cost']) &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.cost is number && data.cost >= 0 &&
             (data.get('stockQuantity', 0) is number);
    }

    function isValidSale(data) {
      return data.keys().hasAll(['invoiceNumber', 'date', 'total']) &&
             data.invoiceNumber is string && data.invoiceNumber.size() <= 100 &&
             data.total is number && data.total >= 0 &&
             data.items is list && data.items.size() > 0;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['date', 'amount', 'description']) &&
             data.amount is number && data.amount >= 0 &&
             data.description is string && data.description.size() <= 500;
    }

    function isValidContact(data) {
      return data.keys().hasAll(['name', 'type']) &&
             data.name is string && data.name.size() <= 200 &&
             data.type in ['Customer', 'Supplier'];
    }

    function isValidStockAdjustment(data) {
      return data.keys().hasAll(['date', 'productId', 'type', 'quantity', 'reason', 'userId']) &&
             data.productId is string && data.productId.size() <= 128 &&
             data.type in ['add', 'remove'] &&
             data.quantity is number && data.quantity > 0;
    }

    // ===============================================================
    // Collection Matches
    // ===============================================================

    match /users/{userId} {
      allow get: if isVerified() && (request.auth.uid == userId || getUserData(userId).companyId == userCompany()) && isValidId(userId);
      allow list: if isVerified() && resource.data.companyId == userCompany();
      // Allow creation during first-time setup or by admin
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']) &&
                    isValidUser(incoming());
    }

    match /companies/{companyId} {
      allow get: if (belongsToCompany(companyId) || isAdmin()) && isValidId(companyId);
      allow create: if isVerified() && isValidId(companyId) && isValidCompany(incoming());
      allow update: if belongsToCompany(companyId) && userRole() == 'admin' &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'logo', 'deliveryNumber', 'address', 'email', 'website', 'currency', 'updatedAt']) &&
                    incoming().ownerId == existing().ownerId; // Immutable owner

      // Sub-collections
      
      match /products/{productId} {
        allow get: if belongsToCompany(companyId) && isValidId(productId);
        allow list: if belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId) && isValidProduct(incoming());
        allow update: if isAccountant() && belongsToCompany(companyId) && isValidProduct(incoming());
        allow delete: if isAccountant() && belongsToCompany(companyId);
      }

      match /categories/{categoryId} {
        allow get: if belongsToCompany(companyId) && isValidId(categoryId);
        allow list: if belongsToCompany(companyId);
        allow write: if isAccountant() && belongsToCompany(companyId);
      }

      match /contacts/{contactId} {
        allow get: if belongsToCompany(companyId) && isValidId(contactId);
        allow list: if belongsToCompany(companyId);
        allow write: if isAccountant() && belongsToCompany(companyId) && isValidContact(incoming());
      }

      match /expenses/{expenseId} {
        allow get: if isAccountant() && belongsToCompany(companyId) && isValidId(expenseId);
        allow list: if isAccountant() && belongsToCompany(companyId);
        allow create: if isAccountant() && belongsToCompany(companyId) && isValidExpense(incoming());
        allow update: if isAccountant() && belongsToCompany(companyId) && isValidExpense(incoming());
      }

      match /transactions/{transactionId} {
        allow get: if isAccountant() && belongsToCompany(companyId) && isValidId(transactionId);
        allow list: if isAccountant() && belongsToCompany(companyId);
        allow write: if isAccountant() && belongsToCompany(companyId);
      }

      match /sales/{saleId} {
        allow get: if belongsToCompany(companyId) && isValidId(saleId);
        allow list: if belongsToCompany(companyId);
        allow create: if isCashier() && belongsToCompany(companyId) && isValidSale(incoming());
        // Action-based updates
        allow update: if isAccountant() && belongsToCompany(companyId) && isValidSale(incoming()) && (
          // Allow editing if not terminal status OR by admin
          (existing().get('status', 'draft') != 'paid') || isAdmin() ||
          // Specific action: Mark as paid
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status == 'paid')
        );
        allow delete: if isAdmin();
      }

      match /audit_logs/{logId} {
        allow get: if isAccountant() && belongsToCompany(companyId) && isValidId(logId);
        allow list: if isAccountant() && belongsToCompany(companyId);
        allow create: if belongsToCompany(companyId);
        allow update, delete: if false; // Append-only
      }
      
      match /returns/{returnId} { 
        allow get: if isAccountant() && belongsToCompany(companyId) && isValidId(returnId);
        allow list: if isAccountant() && belongsToCompany(companyId);
        allow write: if isAccountant() && belongsToCompany(companyId); 
      }
      
      match /damaged_items/{damagedId} { 
        allow get: if isAccountant() && belongsToCompany(companyId) && isValidId(damagedId);
        allow list: if isAccountant() && belongsToCompany(companyId);
        allow write: if isAccountant() && belongsToCompany(companyId); 
      }
      
      match /journal_entries/{entryId} { 
        allow get: if isAccountant() && belongsToCompany(companyId) && isValidId(entryId);
        allow list: if isAccountant() && belongsToCompany(companyId);
        allow write: if isAccountant() && belongsToCompany(companyId); 
      }
      
      match /purchase_orders/{orderId} { 
        allow get: if isAccountant() && belongsToCompany(companyId) && isValidId(orderId);
        allow list: if isAccountant() && belongsToCompany(companyId);
        allow write: if isAccountant() && belongsToCompany(companyId) && (
          existing() == null || // Create
          existing().get('status', 'Draft') == 'Draft' || 
          incoming().status == 'Sent' || 
          isAdmin()
        ); 
      }
      
      match /sales_orders/{orderId} { 
        allow get: if belongsToCompany(companyId) && isValidId(orderId);
        allow list: if belongsToCompany(companyId);
        allow write: if isAccountant() && belongsToCompany(companyId); 
      }
      
      match /stock_adjustments/{adjustmentId} { 
        allow get: if isAccountant() && belongsToCompany(companyId) && isValidId(adjustmentId);
        allow list: if isAccountant() && belongsToCompany(companyId);
        allow create: if isCashier() && belongsToCompany(companyId) && isValidStockAdjustment(incoming());
        allow update, delete: if false; // Append-only
      }
    }
  }
}
